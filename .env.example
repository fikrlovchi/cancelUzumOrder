# Loyiha panel bilan bir xil serverda ishlagani uchun to'g'ridan-to'g'ri
# ilova portiga yuboriladi (nginx/TLS orqali emas) — aks holda certbot'ning
# HTTP->HTTPS redirect'i "Host: 127.0.0.1" so'rovini 404 bilan qaytaradi.
PANEL_INGEST_URL=http://127.0.0.1:3000/api/ingest/runs
PANEL_PROJECT_SLUG=cancel-uzum-order
PANEL_API_KEY=

# MoySklad API tokeni (panel "O'zgaruvchilar" sahifasidan boshqariladi)
MOYSKLAD_TOKEN=

# Har bir Uzum kabinet uchun kunlik so'rovlar chegarasi. Servis shu chegaraga
# yetganda Uzum'ga boshqa so'rov yubormaydi va run "partial" deb belgilanadi.
# CANCELED buyurtmalar sahifa kursori bilan o'qilgani uchun steady-state'da
# do'kon boshiga run'da atigi 1-2 so'rov ketadi; dastlabki backfill esa bir necha
# run/kunga cho'zilishi mumkin (kursor progressni saqlaydi).
UZUM_DAILY_REQUEST_LIMIT=500

# Uzum kabinetlari va do'konlari. Panel "Muhit sozlamalari" orqali bog'lanadi:
#   UZUM_TOKEN_<KABINET>          -> manba: Uzum kabinet (token)
#   UZUM_SHOP_<KABINET>_<BELGI>   -> manba: Uzum do'kon (shop_id)
# <KABINET> nomi ikkala kalitda ham bir xil bo'lishi shart. Bitta kabinetga
# istalgancha do'kon qo'shsa bo'ladi (belgisi ixtiyoriy, faqat takrorlanmasin).
UZUM_TOKEN_MAIN=
UZUM_SHOP_MAIN_1=
